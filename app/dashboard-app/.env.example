# Local development only. The production bundle contains NO secrets or API keys
# (Requirement 10.4): the dashboard talks to same-origin SSE/control endpoints
# served by the Go dashboard service, gated at the CloudFront edge.
#
# Point the Vite dev server's proxy at a locally running dashboard service so
# /dash/stream, /dash/verify, /dash/run, /dash/stop and /ingest resolve.
DASH_DEV_BACKEND=http://localhost:8080
